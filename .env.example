# Copia a .env y ajusta los valores. No subas .env al repositorio.
# docker-compose up leerá .env automáticamente.

# Base de datos MySQL
MYSQL_DATABASE=primaria_db
MYSQL_USER=primaria
MYSQL_PASSWORD=cambiar_password_seguro
MYSQL_ROOT_PASSWORD=cambiar_root_password_seguro

# Secreto compartido Backend <-> IA (FastAPI)
IA_SECRET=cambiar_secret_ia

# Opcional: URL base de la API para el frontend (build time).
# Por defecto /api (mismo origen cuando nginx hace proxy). Si API va en otro dominio:
# VITE_API_URL=https://api.tudominio.com/api
VITE_API_URL=/api
